<div class="ruby-demo-container">
  <h1>🎓 Ruby Syntax Complete Guide</h1>
  <p class="subtitle">JavaScript Developer'dan Ruby Developer'a Geçiş Rehberi</p>
  
  <!-- 1. VARIABLES & DATA TYPES -->
  <section class="demo-section">
    <h2>1. 📦 Variables & Data Types</h2>
    <div class="comparison-grid">
      <div class="js-example">
        <h4>JavaScript</h4>
        <pre><code>const studentName = "Ramazan";
const courseRating = 4.8;
const isEnrolled = true;
const graduationDate = null;</code></pre>
      </div>
      <div class="ruby-example">
        <h4>Ruby</h4>
        <pre><code>@student_name = "Ramazan"
@course_rating = 4.8
@is_enrolled = true
@graduation_date = nil</code></pre>
      </div>
    </div>
    
    <div class="output-box">
      <h4>🔍 Output:</h4>
      <ul>
        <li><strong>Student Name:</strong> <%= @student_name %> (String)</li>
        <li><strong>Course:</strong> <%= @course_name %> (String)</li>
        <li><strong>Age:</strong> <%= @student_age %> (Integer)</li>
        <li><strong>Rating:</strong> <%= @course_rating %> (Float)</li>
        <li><strong>Enrolled:</strong> <%= @is_enrolled %> (Boolean)</li>
        <li><strong>Status:</strong> <%= @status %> (Symbol - Ruby'ye özel!)</li>
        <li><strong>Graduation:</strong> <%= @graduation_date.inspect %> (nil)</li>
      </ul>
    </div>
  </section>

  <!-- 2. STRING OPERATIONS -->
  <section class="demo-section">
    <h2>2. 🔤 String Operations</h2>
    <div class="comparison-grid">
      <div class="js-example">
        <h4>JavaScript</h4>
        <pre><code>const message = `Merhaba ${name}!`;
const upper = name.toUpperCase();
const lower = name.toLowerCase();</code></pre>
      </div>
      <div class="ruby-example">
        <h4>Ruby</h4>
        <pre><code>message = "Merhaba #{@student_name}!"
upper = @student_name.upcase
lower = @student_name.downcase</code></pre>
      </div>
    </div>
    
    <div class="output-box">
      <h4>🔍 Output:</h4>
      <ul>
        <li><strong>Welcome Message:</strong> <%= @welcome_message %></li>
        <li><strong>Uppercase:</strong> <%= @uppercase_name %></li>
        <li><strong>Lowercase:</strong> <%= @lowercase_name %></li>
        <li><strong>Length:</strong> <%= @name_length %> characters</li>
      </ul>
    </div>
  </section>

  <!-- 3. ARRAYS -->
  <section class="demo-section">
    <h2>3. 📝 Arrays (Lists)</h2>
    <div class="comparison-grid">
      <div class="js-example">
        <h4>JavaScript</h4>
        <pre><code>const languages = ['Ruby', 'JavaScript', 'Python'];
const numbers = [1, 2, 3, 4, 5];
const mixed = ['Ruby', 42, true, null];</code></pre>
      </div>
      <div class="ruby-example">
        <h4>Ruby</h4>
        <pre><code>languages = ['Ruby', 'JavaScript', 'Python']
numbers = [1, 2, 3, 4, 5]
mixed = ['Ruby', 42, true, :symbol, nil]</code></pre>
      </div>
    </div>
    
    <div class="output-box">
      <h4>🔍 Arrays in Action:</h4>
      <ul>
        <li><strong>Programming Languages:</strong> <%= @programming_languages.join(', ') %></li>
        <li><strong>Numbers:</strong> <%= @numbers.join(', ') %></li>
        <li><strong>Mixed Array:</strong> <%= @mixed_array.join(', ') %></li>
      </ul>
    </div>
  </section>

  <!-- 4. ARRAY METHODS -->
  <section class="demo-section">
    <h2>4. 🔄 Array Methods (Iteration)</h2>
    
    <div class="method-demo">
      <h4>📌 .each (forEach benzeri)</h4>
      <div class="comparison-grid">
        <div class="js-example">
          <pre><code>languages.forEach(lang => {
  console.log(`${lang} is awesome!`);
});</code></pre>
        </div>
        <div class="ruby-example">
          <pre><code>languages.each do |lang|
  puts "#{lang} is awesome!"
end</code></pre>
        </div>
      </div>
      <div class="result">
        <strong>Result:</strong>
        <ul>
          <% @each_example.each do |item| %>
            <li><%= item %></li>
          <% end %>
        </ul>
      </div>
    </div>

    <div class="method-demo">
      <h4>📌 .map (map benzeri)</h4>
      <div class="comparison-grid">
        <div class="js-example">
          <pre><code>const upperLanguages = languages.map(lang => 
  lang.toUpperCase()
);</code></pre>
        </div>
        <div class="ruby-example">
          <pre><code>upper_languages = languages.map do |lang|
  lang.upcase
end</code></pre>
        </div>
      </div>
      <div class="result">
        <strong>Result:</strong> <%= @map_example.join(', ') %>
      </div>
    </div>

    <div class="method-demo">
      <h4>📌 .select (filter benzeri)</h4>
      <div class="comparison-grid">
        <div class="js-example">
          <pre><code>const evenNumbers = numbers.filter(num => 
  num % 2 === 0
);</code></pre>
        </div>
        <div class="ruby-example">
          <pre><code>even_numbers = numbers.select do |num|
  num.even?
end</code></pre>
        </div>
      </div>
      <div class="result">
        <strong>Even Numbers:</strong> <%= @select_example.join(', ') %>
      </div>
    </div>

    <div class="method-demo">
      <h4>📌 .find (find benzeri)</h4>
      <div class="comparison-grid">
        <div class="js-example">
          <pre><code>const pythonLang = languages.find(lang => 
  lang.startsWith('P')
);</code></pre>
        </div>
        <div class="ruby-example">
          <pre><code>python_lang = languages.find do |lang|
  lang.start_with?('P')
end</code></pre>
        </div>
      </div>
      <div class="result">
        <strong>Found:</strong> <%= @find_example %>
      </div>
    </div>
  </section>

  <!-- 5. HASHES (Objects) -->
  <section class="demo-section">
    <h2>5. 🗂️ Hashes (Objects)</h2>
    <div class="comparison-grid">
      <div class="js-example">
        <h4>JavaScript</h4>
        <pre><code>const student = {
  name: "Ramazan",
  age: 25,
  enrolled: true
};

// Access: student.name or student['name']</code></pre>
      </div>
      <div class="ruby-example">
        <h4>Ruby</h4>
        <pre><code>student = {
  name: "Ramazan",      # Symbol key
  age: 25,
  enrolled: true
}

# Access: student[:name]</code></pre>
      </div>
    </div>
    
    <div class="output-box">
      <h4>🔍 Hash Examples:</h4>
      <div class="hash-examples">
        <div class="hash-example">
          <strong>Student Info (Symbol keys):</strong>
          <ul>
            <% @student_info.each do |key, value| %>
              <li><code>:<%= key %></code> → <%= value.is_a?(Array) ? value.join(', ') : value %></li>
            <% end %>
          </ul>
        </div>
        
        <div class="hash-example">
          <strong>Course Info (Hash rocket syntax):</strong>
          <ul>
            <% @course_info.each do |key, value| %>
              <li><code>:<%= key %></code> → <%= value %></li>
            <% end %>
          </ul>
        </div>
        
        <div class="hash-example">
          <strong>Hash Operations:</strong>
          <ul>
            <li><strong>Keys:</strong> <%= @hash_keys.join(', ') %></li>
            <li><strong>Values:</strong> <%= @hash_values.join(', ') %></li>
            <li><strong>Has :name key?</strong> <%= @has_name_key %></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. CONDITIONALS -->
  <section class="demo-section">
    <h2>6. 🤔 Conditionals (if/else)</h2>
    <div class="comparison-grid">
      <div class="js-example">
        <h4>JavaScript</h4>
        <pre><code>if (age >= 18) {
  status = "Adult";
} else if (age >= 13) {
  status = "Teenager";
} else {
  status = "Child";
}

const enrollment = isEnrolled ? "Yes" : "No";</code></pre>
      </div>
      <div class="ruby-example">
        <h4>Ruby</h4>
        <pre><code>if age >= 18
  status = "Adult"
elsif age >= 13
  status = "Teenager"
else
  status = "Child"
end

enrollment = is_enrolled ? "Yes" : "No"</code></pre>
      </div>
    </div>
    
    <div class="output-box">
      <h4>🔍 Conditional Results:</h4>
      <ul>
        <li><strong>Age Status:</strong> <%= @age_status %> (Age: <%= @student_age %>)</li>
        <li><strong>Enrollment Status:</strong> <%= @enrollment_status %></li>
        <li><strong>Difficulty Level (case/when):</strong> <%= @difficulty_level %> (Rating: <%= @course_rating %>)</li>
      </ul>
    </div>
  </section>

  <!-- 7. LOOPS -->
  <section class="demo-section">
    <h2>7. 🔁 Loops & Iterations</h2>
    
    <div class="loop-demo">
      <h4>📌 .times (Ruby özel)</h4>
      <div class="comparison-grid">
        <div class="js-example">
          <pre><code>for (let i = 0; i < 5; i++) {
  console.log(`Iteration ${i + 1}`);
}</code></pre>
        </div>
        <div class="ruby-example">
          <pre><code>5.times do |i|
  puts "Iteration #{i + 1}"
end</code></pre>
        </div>
      </div>
      <div class="result">
        <strong>Result:</strong> <%= @times_example.join(', ') %>
      </div>
    </div>

    <div class="loop-demo">
      <h4>📌 Range iteration</h4>
      <div class="comparison-grid">
        <div class="js-example">
          <pre><code>for (let i = 1; i <= 5; i++) {
  console.log(`Number: ${i}`);
}</code></pre>
        </div>
        <div class="ruby-example">
          <pre><code>(1..5).each do |num|
  puts "Number: #{num}"
end</code></pre>
        </div>
      </div>
      <div class="result">
        <strong>Result:</strong> <%= @range_example.join(', ') %>
      </div>
    </div>

    <div class="loop-demo">
      <h4>📌 .upto method</h4>
      <div class="ruby-example">
        <pre><code>1.upto(3) do |num|
  puts "Count: #{num}"
end</code></pre>
      </div>
      <div class="result">
        <strong>Result:</strong> <%= @upto_example.join(', ') %>
      </div>
    </div>
  </section>

  <!-- 8. BLOCKS & PROCS -->
  <section class="demo-section">
    <h2>8. 🧩 Blocks, Procs & Lambdas</h2>
    <div class="comparison-grid">
      <div class="js-example">
        <h4>JavaScript</h4>
        <pre><code>const multiplyByTwo = x => x * 2;
const result = numbers.map(multiplyByTwo);

const square = function(x) {
  return x * x;
};</code></pre>
      </div>
      <div class="ruby-example">
        <h4>Ruby</h4>
        <pre><code>multiply_by_two = Proc.new { |x| x * 2 }
result = numbers.map(&multiply_by_two)

square = lambda { |x| x * x }</code></pre>
      </div>
    </div>
    
    <div class="output-box">
      <h4>🔍 Function Results:</h4>
      <ul>
        <li><strong>Proc example:</strong> <%= @proc_example.join(', ') %></li>
        <li><strong>Lambda example:</strong> <%= @lambda_example.join(', ') %></li>
      </ul>
    </div>
  </section>

  <!-- 9. DATABASE OPERATIONS -->
  <section class="demo-section">
    <h2>9. 🗄️ Database Operations (ActiveRecord)</h2>
    <div class="comparison-grid">
      <div class="js-example">
        <h4>JavaScript (Sequelize)</h4>
        <pre><code>const demos = await Demo.findAll();
const published = await Demo.findAll({
  where: { published: true }
});
const variables = await Demo.findAll({
  where: { category: 'variables' }
});</code></pre>
      </div>
      <div class="ruby-example">
        <h4>Ruby (ActiveRecord)</h4>
        <pre><code>demos = RubySyntaxDemo.all
published = RubySyntaxDemo.published
variables = RubySyntaxDemo.by_category('variables')</code></pre>
      </div>
    </div>
    
    <div class="output-box">
      <h4>🔍 Database Results:</h4>
      <div class="db-stats">
        <div class="stat-card">
          <h4>📊 Statistics</h4>
          <ul>
            <% @demo_stats.each do |key, value| %>
              <li><strong><%= key.to_s.humanize %>:</strong> 
                <%= value.is_a?(Array) ? value.join(', ') : value %>
              </li>
            <% end %>
          </ul>
        </div>
        
        <div class="stat-card">
          <h4>📚 Demo Records</h4>
          <ul>
            <li><strong>Total Demos:</strong> <%= @all_demos.count %></li>
            <li><strong>Published:</strong> <%= @published_demos.count %></li>
            <li><strong>Variables Category:</strong> <%= @variable_demos.count %></li>
          </ul>
        </div>
      </div>
      
      <div class="demo-list">
        <h4>📋 All Ruby Demos:</h4>
        <ul>
          <% @all_demos.each do |demo| %>
            <li class="<%= demo.published? ? 'published' : 'draft' %>">
              <strong><%= demo.formatted_title %></strong>
              <span class="category">(<%= demo.category %>)</span>
              <span class="status"><%= demo.published? ? '✅ Published' : '📝 Draft' %></span>
              <br>
              <small><%= demo.summary(8) %></small>
              <div class="demo-meta">
                <span>📝 Words: <%= demo.word_count %></span>
                <span>🏷️ Tags: <%= demo.tags.join(', ') %></span>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </section>

  <!-- 10. ERROR HANDLING -->
  <section class="demo-section">
    <h2>10. ⚠️ Error Handling</h2>
    <div class="comparison-grid">
      <div class="js-example">
        <h4>JavaScript</h4>
        <pre><code>try {
  const result = 10 / 2;
  console.log(result);
} catch (error) {
  console.error('Error:', error.message);
} finally {
  console.log('Always runs');
}</code></pre>
      </div>
      <div class="ruby-example">
        <h4>Ruby</h4>
        <pre><code>begin
  result = 10 / 2
  puts result
rescue => error
  puts "Error: #{error.message}"
ensure
  puts "Always runs"
end</code></pre>
      </div>
    </div>
    
    <div class="output-box">
      <h4>🔍 Error Handling Result:</h4>
      <ul>
        <li><strong>Division Result:</strong> <%= @division_result %></li>
        <li><strong>Division Attempted:</strong> <%= @division_attempted %></li>
      </ul>
    </div>
  </section>

  <!-- 11. REGULAR EXPRESSIONS -->
  <section class="demo-section">
    <h2>11. 🔍 Regular Expressions</h2>
    <div class="comparison-grid">
      <div class="js-example">
        <h4>JavaScript</h4>
        <pre><code>const emailPattern = /^[\w+\-.]+@[a-z\d\-]+(\.[a-z\d\-]+)*\.[a-z]+$/i;
const isValid = emailPattern.test(email);</code></pre>
      </div>
      <div class="ruby-example">
        <h4>Ruby</h4>
        <pre><code>email_pattern = /\A[\w+\-.]+@[a-z\d\-]+(\.[a-z\d\-]+)*\.[a-z]+\z/i
is_valid = email.match?(email_pattern)</code></pre>
      </div>
    </div>
    
    <div class="output-box">
      <h4>🔍 Email Validation Results:</h4>
      <ul>
        <% @email_validation_results.each do |result| %>
          <li>
            <code><%= result[:email] %></code> 
            <span class="<%= result[:valid] ? 'valid' : 'invalid' %>">
              <%= result[:valid] ? '✅ Valid' : '❌ Invalid' %>
            </span>
          </li>
        <% end %>
      </ul>
    </div>
  </section>

  <!-- Navigation -->
  <div class="navigation-section">
    <h2>🧭 Navigate to Other Examples</h2>
    <div class="nav-buttons">
      <%= link_to "🏠 Ana Sayfa", root_path, class: "btn btn-secondary" %>
      <%= link_to "👋 Hello World (Server-Side)", hello_path, class: "btn btn-primary" %>
      <%= link_to "⚡ Vue.js Demo (Client-Side)", vue_path, class: "btn btn-success" %>
    </div>
  </div>
</div>

<style>
  .ruby-demo-container {
    max-width: 1200px;
    margin: 20px auto;
    padding: 20px;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    line-height: 1.6;
  }
  
  .subtitle {
    text-align: center;
    color: #6c757d;
    font-size: 1.2em;
    margin-bottom: 40px;
  }
  
  .demo-section {
    background: #f8f9fa;
    border-radius: 10px;
    padding: 25px;
    margin: 30px 0;
    border-left: 5px solid #dc3545;
  }
  
  .demo-section h2 {
    color: #dc3545;
    margin-top: 0;
    border-bottom: 2px solid #dee2e6;
    padding-bottom: 10px;
  }
  
  .comparison-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin: 20px 0;
  }
  
  .js-example, .ruby-example {
    background: white;
    border-radius: 8px;
    padding: 15px;
    border: 1px solid #dee2e6;
  }
  
  .js-example h4 {
    color: #f7df1e;
    background: #323330;
    margin: -15px -15px 15px -15px;
    padding: 10px 15px;
    border-radius: 8px 8px 0 0;
  }
  
  .ruby-example h4 {
    color: #fff;
    background: #cc342d;
    margin: -15px -15px 15px -15px;
    padding: 10px 15px;
    border-radius: 8px 8px 0 0;
  }
  
  pre {
    background: #f1f3f4;
    padding: 15px;
    border-radius: 5px;
    overflow-x: auto;
    margin: 0;
    border: 1px solid #e9ecef;
  }
  
  code {
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
    font-size: 0.9em;
  }
  
  .output-box {
    background: #d4edda;
    border: 1px solid #c3e6cb;
    border-radius: 8px;
    padding: 20px;
    margin: 20px 0;
  }
  
  .output-box h4 {
    color: #155724;
    margin-top: 0;
  }
  
  .method-demo, .loop-demo {
    background: white;
    border-radius: 8px;
    padding: 20px;
    margin: 20px 0;
    border: 1px solid #dee2e6;
  }
  
  .method-demo h4, .loop-demo h4 {
    color: #495057;
    margin-top: 0;
  }
  
  .result {
    background: #e2e3e5;
    padding: 15px;
    border-radius: 5px;
    margin-top: 15px;
    border-left: 4px solid #6c757d;
  }
  
  .hash-examples {
    display: grid;
    grid-template-columns: 1fr;
    gap: 15px;
  }
  
  .hash-example {
    background: white;
    padding: 15px;
    border-radius: 5px;
    border: 1px solid #dee2e6;
  }
  
  .db-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin: 20px 0;
  }
  
  .stat-card {
    background: white;
    padding: 20px;
    border-radius: 8px;
    border: 1px solid #dee2e6;
  }
  
  .stat-card h4 {
    color: #495057;
    margin-top: 0;
  }
  
  .demo-list {
    background: white;
    padding: 20px;
    border-radius: 8px;
    border: 1px solid #dee2e6;
    margin-top: 20px;
  }
  
  .demo-list h4 {
    color: #495057;
    margin-top: 0;
  }
  
  .demo-list li {
    padding: 15px;
    border-bottom: 1px solid #e9ecef;
    list-style: none;
  }
  
  .demo-list li.published {
    background: #d4edda;
  }
  
  .demo-list li.draft {
    background: #fff3cd;
  }
  
  .category {
    background: #007bff;
    color: white;
    padding: 2px 8px;
    border-radius: 3px;
    font-size: 0.8em;
  }
  
  .status {
    margin-left: 10px;
    font-size: 0.9em;
  }
  
  .demo-meta {
    margin-top: 8px;
    font-size: 0.85em;
    color: #6c757d;
  }
  
  .demo-meta span {
    margin-right: 15px;
  }
  
  .valid {
    color: #28a745;
    font-weight: bold;
  }
  
  .invalid {
    color: #dc3545;
    font-weight: bold;
  }
  
  .navigation-section {
    background: #e9ecef;
    padding: 30px;
    border-radius: 10px;
    text-align: center;
    margin-top: 50px;
  }
  
  .nav-buttons {
    display: flex;
    justify-content: center;
    gap: 15px;
    flex-wrap: wrap;
    margin-top: 20px;
  }
  
  .btn {
    display: inline-block;
    padding: 12px 24px;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 500;
    transition: all 0.3s ease;
  }
  
  .btn-primary {
    background-color: #007bff;
    color: white;
  }
  
  .btn-secondary {
    background-color: #6c757d;
    color: white;
  }
  
  .btn-success {
    background-color: #28a745;
    color: white;
  }
  
  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
  }
  
  /* Responsive */
  @media (max-width: 768px) {
    .comparison-grid, .db-stats {
      grid-template-columns: 1fr;
    }
    
    .nav-buttons {
      flex-direction: column;
      align-items: center;
    }
    
    .btn {
      width: 100%;
      max-width: 300px;
    }
  }
</style>
