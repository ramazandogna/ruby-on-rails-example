<div class="hello-container">
  <h1><%= @message %></h1>
  <p>Şu anki zaman: <%= @current_time.strftime("%d/%m/%Y %H:%M:%S") %></p>
  
  <div class="greeting-info">
    <h3>Bu selamlama:</h3>
    <p><strong>Dil:</strong> <%= @greeting.language.upcase %></p>
    <p><strong>Mesaj:</strong> <%= @greeting.message %></p>
    <p><small>Her yenileme'de farklı bir selamlama gösterilir!</small></p>
  </div>
  
  <div class="info-box">
    <h3>Ruby on Rails MVC Yapısı:</h3>
    <ul>
      <li><strong>Model:</strong> <code>Greeting</code> model'i - Veritabanından random selamlama çekti</li>
      <li><strong>View:</strong> Bu dosya (<code>app/views/home/hello.html.erb</code>)</li>
      <li><strong>Controller:</strong> <code>HomeController#hello</code> action'ı</li>
    </ul>
  </div>
  
  <div class="navigation">
    <%= link_to "← Ana Sayfaya Dön", root_path, class: "btn btn-secondary" %>
    <%= link_to "🔄 Yenile", hello_path, class: "btn btn-primary" %>
  </div>
</div>

<style>
  .hello-container {
    max-width: 600px;
    margin: 50px auto;
    padding: 20px;
    font-family: Arial, sans-serif;
    text-align: center;
  }
  
  .greeting-info {
    background-color: #fff3cd;
    border: 1px solid #ffeaa7;
    border-radius: 8px;
    padding: 20px;
    margin: 20px 0;
  }
  
  .info-box {
    background-color: #f0f8ff;
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 20px;
    margin-top: 30px;
    text-align: left;
  }
  
  .navigation {
    margin-top: 30px;
  }
  
  .btn {
    display: inline-block;
    padding: 10px 20px;
    margin: 0 10px;
    text-decoration: none;
    border-radius: 5px;
    transition: background-color 0.3s;
  }
  
  .btn-primary {
    background-color: #007bff;
    color: white;
  }
  
  .btn-primary:hover {
    background-color: #0056b3;
  }
  
  .btn-secondary {
    background-color: #6c757d;
    color: white;
  }
  
  .btn-secondary:hover {
    background-color: #545b62;
  }
  
  h1 {
    color: #2c5aa0;
    font-size: 2.5em;
  }
  
  code {
    background-color: #e9ecef;
    padding: 2px 4px;
    border-radius: 3px;
    font-family: monospace;
  }
</style>
